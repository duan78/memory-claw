{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": ".",
    "types": []
  },
  "include": ["index.ts", "src/**/*.ts", "locales/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
