{
  "permissions": {
    "allow": [
      "Bash(grep -E \"\\\\.\\(log|txt\\)$\")",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(npm install:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(export HOME=/root)",
      "Bash(git config:*)",
      "Bash(rm -rf ~/.openclaw/memory/memory-claw)",
      "Bash(cp -r ~/.openclaw/memory/memory-claw-backup-256d ~/.openclaw/memory/memory-claw)",
      "Bash(node:*)",
      "Bash(cat:*)",
      "Bash(tmux send-keys:*)",
      "Bash(find ~/.openclaw -name *.log -type f)",
      "Bash(journalctl --user -u openclaw* -n 50)",
      "Bash(kill -USR1 3531136)",
      "Bash(ps -p 3531136 -o pid,cmd,etime)",
      "Bash(tmux attach:*)",
      "Bash(tmux new-session:*)"
